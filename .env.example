# Application configuration
APP__ENV=production
APP__LIST_LOG_LEVELS=INFO,DEBUG,WARNING,ERROR,CRITICAL
APP__USE_NGROK=false
APP__PORT=5000
APP__NGROK_AUTHTOKEN=
MODEL_EMBEDDING__NAME=intfloat/multilingual-e5-small

# Vector & SQL configuration
VECTOR__STORE_TYPE=faiss
VECTOR__COLLECTION_NAME_CHUNKS=chunks

VECTOR__WEAVIATE_HOST=localhost
VECTOR__WEAVIATE_PORT=8081
VECTOR__WEAVIATE_API_KEY=
VECTOR__WEAVIATE_GRPC_PORT=50051

VECTOR__CHROMA_HOST=localhost
VECTOR__CHROMA_PORT=8000

# Qdrant Settings
VECTOR__QDRANT_HOST=qdrant
VECTOR__QDRANT_PORT=6333
VECTOR__QDRANT_GRPC_PORT=6334
VECTOR__QDRANT_API_KEY=

# Redis Configuration
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=password

AUTH__ENABLE_GOOGLE=False
AUTH__GOOGLE_CLIENT_ID=
AUTH__GOOGLE_CLIENT_SECRET=
AUTH__JWT_SECRET=